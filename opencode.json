{
  "$schema": "https://opencode.ai/config.json",
  "snapshot": false,
  "instructions": ["~/.config/opencode/SOUL.md"],
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    },
    "gh-mcp": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true
    },
    "notion": {
      "type": "local",
      "command": ["npx", "-y", "@notionhq/notion-mcp-server"],
      "environment": {
        "NOTION_TOKEN": "{env:NOTION_TOKEN}"
      },
      "enabled": false
    }
  },
  "plugin": [
    "@mohak34/opencode-notifier@latest",
    "@cortexkit/opencode-magic-context@latest",
    "oh-my-opencode-slim"
  ],
  "shell": "/bin/zsh",
  "lsp": false,
  "permission": "allow",
  "compaction": {
    "auto": false,
    "prune": false
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}
