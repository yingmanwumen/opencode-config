{
  "command": {
    "enabled": false,
    "path": "/bin/bash",
    "args": [
      "-c",
      "curl -s -X POST https://ntfy.sh/ymwm_opencode_notification -d '{message}'"
    ]
  },

  "sound": false,
  "notification": true,
  "bell": false,
  "timeout": 5,
  "showProjectName": true,
  "showFullPath": false,
  "showSessionTitle": true,
  "showIcon": true,
  "customIconPath": null,
  "suppressWhenFocused": false,
  "enableOnDesktop": true,
  "notificationSystem": "osascript",
  "linux": {
    "grouping": false
  },
  "minDuration": 0,
  "events": {
    "permission": {
      "sound": true,
      "notification": true,
      "command": true,
      "bell": false
    },
    "complete": {
      "sound": true,
      "notification": true,
      "command": true,
      "bell": false
    },
    "subagent_complete": {
      "sound": false,
      "notification": false,
      "command": false,
      "bell": false
    },
    "error": {
      "sound": true,
      "notification": true,
      "command": true,
      "bell": false
    },
    "question": {
      "sound": true,
      "notification": true,
      "command": true,
      "bell": false
    },
    "user_cancelled": {
      "sound": false,
      "notification": false,
      "command": false,
      "bell": false
    },
    "plan_exit": {
      "sound": true,
      "notification": true,
      "command": true,
      "bell": false
    },
    "session_started": {
      "sound": true,
      "notification": false,
      "command": false,
      "bell": false
    },
    "user_message": {
      "sound": true,
      "notification": false,
      "command": false,
      "bell": false
    },
    "client_connected": {
      "sound": true,
      "notification": false,
      "command": false,
      "bell": false
    }
  },
  "messages": {
    "permission": "[{projectName}] Session needs permission: {sessionTitle}",
    "complete": "[{projectName}] Session has finished: {sessionTitle}",
    "subagent_complete": "[{projectName}] Subagent task completed: {sessionTitle}",
    "error": "[{projectName}] Session encountered an error: {sessionTitle}",
    "question": "[{projectName}] Session has a question: {sessionTitle}",
    "user_cancelled": "[{projectName}] Session was cancelled by user: {sessionTitle}",
    "plan_exit": "[{projectName}] Plan ready for review: {sessionTitle}",
    "session_started": "[{projectName}] Session started: {sessionTitle}",
    "user_message": "[{projectName}] User sent a message: {sessionTitle}",
    "client_connected": "OpenCode connected"
  },
  "sounds": {
    "permission": null,
    "complete": null,
    "subagent_complete": null,
    "error": null,
    "question": null,
    "user_cancelled": null,
    "plan_exit": null,
    "session_started": null,
    "user_message": null,
    "client_connected": null
  },
  "volumes": {
    "permission": 1,
    "complete": 1,
    "subagent_complete": 1,
    "error": 1,
    "question": 1,
    "user_cancelled": 1,
    "plan_exit": 1,
    "session_started": 1,
    "user_message": 1,
    "client_connected": 1
  }
}
